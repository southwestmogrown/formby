# Supabase — get these from your project's API settings
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key — server-side only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Anthropic API key — used by /api/generate to call Claude
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Maximum number of form generations allowed per demo session (per IP)
DEMO_GENERATION_LIMIT=3
